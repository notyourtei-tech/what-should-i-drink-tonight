generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  inventory  InventoryItem[]
  favorites  Favorite[]
  customDrinks CustomDrink[]
  drinkLogs  DrinkLog[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model InventoryItem {
  id        String   @id @default(cuid())
  userId    String
  category  String
  name      String
  brand     String?
  quantity  Float?
  unit      String   @default("ml")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, name])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  drinkId   String?
  drinkName String
  drinkData String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, drinkId])
  @@unique([userId, drinkName])
  @@index([userId])
}

model CustomDrink {
  id         String   @id @default(cuid())
  userId     String
  name       String
  ingredients String
  steps      String
  tags       String
  difficulty String
  abv        Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DrinkLog {
  id        String   @id @default(cuid())
  userId    String
  drinkName String
  rating    Int?
  notes     String?
  consumedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
}

model DrinkRecipe {
  id          String   @id @default(cuid())
  name        String   @unique
  nameEn      String?
  nameJa      String?
  category    String
  description String?
  image       String?
  ingredients String
  steps       String
  tags        String
  difficulty  String   @default("easy")
  abv         Float?
  glassType   String?
  iceType     String?
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([category])
}